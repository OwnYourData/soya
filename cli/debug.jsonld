                        "title": "Telefon"
                      }
                    }
                  }
                }
              },
              "intermediary": {
                "type": "object",
                "readOnly": true,
                "title": "Intermediär (DGA Art. 10)",
                "properties": {
                  "subjectTitle": {
                    "type": "string",
                    "title": "Bezeichnung"
                  },
                  "subjectType": {
                    "type": "string",
                    "title": "Rechtsform"
                  },
