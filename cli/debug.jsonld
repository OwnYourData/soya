                      },
                      {
                        "const": "NonProfitFoundationFund",
                        "title": "Gemeinnützige Stiftung / Fonds"
                      },
                      {
                        "const": "VVaG",
                        "title": "Versicherungsverein auf Gegenseitigkeit (VVaG)"
                      },
                      {
                        "const": "EWIV",
                        "title": "Europäische wirtschaftliche Interessenvereinigung (EWIV / EEIG)"
                      },
                      {
                        "const": "PublicLawCorporation",
                        "title": "Körperschaft öffentlichen Rechts"
                      }
                    ]
                  },
                  "subjectDID": {
                    "type": "string",
                    "readOnly": true,
                    "title": "DID"
                  },
                  "subjectBPK": {
                    "type": "string",
                    "readOnly": true,
                    "title": "bPK"
                  },
                  "subjectRegisteredNumber": {
                    "type": "string",
                    "title": "Registernummer"
                  },
                  "subjectContact": {
                    "type": "object",
                    "title": "Kontakt",
                    "properties": {
                      "identityName": {
