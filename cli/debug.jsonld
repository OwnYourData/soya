                    "sh:minCount": 0,
                    "sh:maxCount": 1
                  },
                  {
                    "sh:path": "updateFrequency",
                    "sh:minCount": 0,
                    "sh:maxCount": 1
                  },
                  {
                    "sh:path": "granularity",
                    "sh:minCount": 0,
                    "sh:maxCount": 1
                  },
                  {
                    "sh:path": "updateStrategy",
                    "sh:minCount": 0,
                    "sh:maxCount": 1
                  }
                ]
              },
              "sh:minCount": 0
            }
          ]
        },
        {
          "sh:path": "ucConfig",
          "sh:minCount": 1,
          "sh:maxCount": 1
        }
      ]
    },
    {
      "@id": "D2ATransformation",
      "engine": "jq",
      "value": "{useCaseKey: .useCaseKey, dataspaceId: .dataspaceId, contract: {provider: .contract.provider, intermediary: .contract.intermediary, consent: .contract.consent, contractSchema: .contract.contractSchema}, dataModels: .dataModels}\n",
      "@type": "OverlayTransformation",
      "onBase": "D2A",
      "name": "D2AReadTransform"
    },
    {
      "@id": "D2AForm",
      "schema": {
        "type": "object",
        "properties": {
          "useCaseKey": {
            "type": "string",
            "readOnly": true,
            "title": "Use-Case-Schlüssel"
          },
          "dataspaceId": {
            "type": "string",
            "readOnly": true,
            "title": "Datenraum-Referenz"
          },
          "contract": {
            "type": "object",
            "properties": {
              "provider": {
                "type": "object",
                "title": "Datenanbieter",
                "properties": {
                  "subjectTitle": {
                    "type": "string",
                    "title": "Bezeichnung"
                  },
                  "subjectType": {
                    "type": "string",
                    "title": "Rechtsform",
                    "oneOf": [
                      {
                        "const": "EU",
                        "title": "Einzelunternehmen (EU)"
                      },
                      {
                        "const": "GesbR",
                        "title": "Gesellschaft bürgerlichen Rechts (GesbR)"
                      },
