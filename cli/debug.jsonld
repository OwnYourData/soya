      "ui": {
        "type": "VerticalLayout",
        "rule": {
          "effect": "DISABLE",
          "condition": {
            "expectedValue": true
          }
        },
        "elements": [
          {
            "type": "VerticalLayout",
            "elements": [
              {
                "type": "Group",
                "label": "Vertrags-Metadaten",
                "elements": [
                  {
                    "type": "HorizontalLayout",
                    "elements": [
                      {
                        "type": "Control",
                        "scope": "#/properties/useCaseKey"
                      },
                      {
                        "type": "Control",
                        "scope": "#/properties/dataspaceId"
                      }
                    ]
                  },
                  {
                    "type": "Control",
                    "scope": "#/properties/contract/properties/contractSchema"
                  }
                ]
              },
              {
                "type": "Group",
                "label": "Datenanbieter (Slot 1)",
                "elements": [
                  {
                    "type": "Control",
                    "scope": "#/properties/contract/properties/provider/properties/subjectTitle"
                  },
                  {
                    "type": "HorizontalLayout",
                    "elements": [
                      {
                        "type": "Control",
                        "scope": "#/properties/contract/properties/provider/properties/subjectType"
                      },
                      {
                        "type": "Control",
                        "scope": "#/properties/contract/properties/provider/properties/subjectRegisteredNumber"
                      }
                    ]
                  },
                  {
                    "type": "HorizontalLayout",
                    "elements": [
                      {
                        "type": "Control",
                        "scope": "#/properties/contract/properties/provider/properties/subjectDID"
                      },
                      {
                        "type": "Control",
                        "scope": "#/properties/contract/properties/provider/properties/subjectBPK"
                      }
                    ]
                  },
                  {
                    "type": "Group",
                    "label": "Kontakt",
                    "elements": [
                      {
                        "type": "HorizontalLayout",
                        "elements": [
                          {
                            "type": "Control",
                            "scope": "#/properties/contract/properties/provider/properties/subjectContact/properties/identityName"
                          },
                          {
                            "type": "Control",
                            "scope": "#/properties/contract/properties/provider/properties/subjectContact/properties/identityEmail"
                          }
                        ]
                      },
                      {
                        "type": "HorizontalLayout",
                        "elements": [
                          {
                            "type": "Control",
                            "scope": "#/properties/contract/properties/provider/properties/subjectContact/properties/identityAddress"
                          },
                          {
                            "type": "Control",
                            "scope": "#/properties/contract/properties/provider/properties/subjectContact/properties/identityPhone"
                          }
                        ]
                      }
                    ]
                  }
                ]
              },
              {
                "type": "Group",
                "label": "Intermediär (Slot 1 — DGA Art. 10, auto-befüllt aus System-Kontext)",
                "elements": [
                  {
                    "type": "Control",
                    "scope": "#/properties/contract/properties/intermediary"
                  }
                ]
              },
              {
                "type": "Group",
                "label": "Vertragsbedingungen (Slot 1 — Defaults aus Datenraum, vom Vertrag überschreibbar)",
                "elements": [
                  {
                    "type": "Control",
                    "scope": "#/properties/contract/properties/consent/properties/hasPurpose"
                  },
                  {
                    "type": "Control",
                    "scope": "#/properties/contract/properties/consent/properties/hasProcessing"
                  },
                  {
                    "type": "Control",
                    "scope": "#/properties/contract/properties/consent/properties/hasProcessingLocation"
                  },
                  {
                    "type": "Control",
                    "scope": "#/properties/contract/properties/consent/properties/hasStorageLocation"
                  },
                  {
                    "type": "HorizontalLayout",
                    "elements": [
                      {
                        "type": "Control",
                        "scope": "#/properties/contract/properties/consent/properties/hasExpiryTimeDuration"
                      },
                      {
                        "type": "Control",
                        "scope": "#/properties/contract/properties/consent/properties/hasExpiryTimeUnit"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "Group",
                "label": "Datenmodelle (Slot 2)",
                "elements": [
                  {
                    "type": "Control",
                    "scope": "#/properties/dataModels",
                    "options": {
                      "detail": "GENERATED"
                    }
                  }
                ]
              },
              {
                "type": "Group",
                "label": "Use-Case-Konfiguration (Slot 3)",
                "elements": [
                  {
                    "type": "Control",
                    "scope": "#/properties/ucConfig"
                  }
                ]
              }
            ]
          }
        ]
      },
