    {
      "@id": "D2AOverlayValidation",
      "@type": "OverlayValidation",
      "onBase": "D2A",
      "name": "D2AValidation",
      "sh:targetClass": "D2A",
      "sh:property": [
        {
          "sh:path": "useCaseKey",
          "sh:minCount": 1,
          "sh:maxCount": 1
        },
        {
          "sh:path": "dataspaceId",
          "sh:minCount": 1,
          "sh:maxCount": 1
        },
        {
          "sh:path": "contract",
          "sh:minCount": 1,
          "sh:maxCount": 1,
          "sh:property": [
            {
              "sh:path": "provider",
              "sh:minCount": 1,
              "sh:maxCount": 1,
              "sh:property": [
                {
                  "sh:path": "subjectTitle",
                  "sh:minCount": 1,
                  "sh:maxCount": 1,
                  "sh:minLength": 1
                },
                {
                  "sh:path": "subjectType",
                  "sh:minCount": 1,
                  "sh:maxCount": 1,
                  "sh:in": {
                    "@list": [
                      "EU",
                      "GesbR",
                      "OG",
                      "KG",
                      "GmbHCoKG",
                      "SilentPartnership",
                      "GmbH",
                      "FlexCo",
                      "AG",
                      "SE",
                      "Gen",
                      "SCE",
                      "Association",
                      "PrivateFoundation",
                      "NonProfitFoundationFund",
                      "VVaG",
                      "EWIV",
                      "PublicLawCorporation"
                    ]
                  }
                },
                {
                  "sh:path": "subjectDID",
                  "sh:minCount": 1,
                  "sh:maxCount": 1
                },
                {
                  "sh:path": "subjectBPK",
                  "sh:minCount": 0,
                  "sh:maxCount": 1
                },
                {
                  "sh:path": "subjectRegisteredNumber",
                  "sh:minCount": 0,
                  "sh:maxCount": 1
                },
                {
                  "sh:path": "subjectContact",
                  "sh:minCount": 1,
                  "sh:maxCount": 1,
                  "sh:property": [
                    {
                      "sh:path": "identityName",
                      "sh:minCount": 1,
                      "sh:maxCount": 1
                    },
                    {
                      "sh:path": "identityAddress",
                      "sh:minCount": 0,
                      "sh:maxCount": 1
                    },
                    {
                      "sh:path": "identityEmail",
                      "sh:minCount": 0,
                      "sh:maxCount": 1
                    },
                    {
                      "sh:path": "identityPhone",
                      "sh:minCount": 0,
                      "sh:maxCount": 1
                    }
                  ]
                }
              ]
            },
            {
              "sh:path": "intermediary",
              "sh:minCount": 1,
              "sh:maxCount": 1,
              "sh:property": [
                {
                  "sh:path": "subjectTitle",
                  "sh:minCount": 1,
                  "sh:maxCount": 1
                },
                {
                  "sh:path": "subjectType",
                  "sh:minCount": 1,
                  "sh:maxCount": 1,
                  "sh:in": {
                    "@list": [
                      "EU",
                      "GesbR",
                      "OG",
                      "KG",
                      "GmbHCoKG",
                      "SilentPartnership",
                      "GmbH",
                      "FlexCo",
                      "AG",
                      "SE",
                      "Gen",
                      "SCE",
                      "Association",
                      "PrivateFoundation",
                      "NonProfitFoundationFund",
                      "VVaG",
                      "EWIV",
                      "PublicLawCorporation"
                    ]
                  }
                },
                {
                  "sh:path": "subjectDID",
                  "sh:minCount": 1,
                  "sh:maxCount": 1
                },
                {
                  "sh:path": "subjectBPK",
                  "sh:minCount": 0,
                  "sh:maxCount": 1
                },
                {
                  "sh:path": "subjectRegisteredNumber",
                  "sh:minCount": 0,
                  "sh:maxCount": 1
                },
                {
                  "sh:path": "subjectContact",
                  "sh:minCount": 1,
                  "sh:maxCount": 1,
                  "sh:property": [
                    {
                      "sh:path": "identityName",
                      "sh:minCount": 1,
                      "sh:maxCount": 1
                    },
                    {
                      "sh:path": "identityAddress",
                      "sh:minCount": 0,
                      "sh:maxCount": 1
                    },
                    {
                      "sh:path": "identityEmail",
                      "sh:minCount": 0,
                      "sh:maxCount": 1
                    },
                    {
                      "sh:path": "identityPhone",
                      "sh:minCount": 0,
                      "sh:maxCount": 1
                    }
                  ]
                }
              ]
            },
            {
              "sh:path": "consent",
              "sh:minCount": 1,
              "sh:maxCount": 1,
              "sh:property": [
                {
                  "sh:path": {
                    "@list": [
                      {
                        "@id": "hasPurpose"
                      },
                      {
                        "sh:zeroOrMorePath": {
                          "@id": "rdf:rest"
                        }
                      },
                      {
                        "@id": "rdf:first"
                      }
                    ]
                  },
                  "sh:minCount": 1,
                  "sh:datatype": {
                    "@id": "xsd:string"
                  },
                  "sh:in": {
                    "@list": [
                      "CommercialPurpose",
                      "Marketing",
                      "Personalisation",
                      "PublicBenefit",
                      "ResearchAndDevelopment",
                      "ServiceProvision"
                    ]
                  },
                  "@type": "sh:PropertyShape"
                },
                {
                  "sh:path": {
                    "@list": [
                      {
                        "@id": "hasProcessing"
                      },
                      {
                        "sh:zeroOrMorePath": {
                          "@id": "rdf:rest"
                        }
                      },
                      {
                        "@id": "rdf:first"
                      }
                    ]
                  },
                  "sh:minCount": 1,
                  "sh:datatype": {
                    "@id": "xsd:string"
                  },
                  "sh:in": {
                    "@list": [
                      "Disclose",
                      "Organise",
                      "Store",
                      "Transform",
                      "Use"
                    ]
                  },
                  "@type": "sh:PropertyShape"
                },
                {
                  "sh:path": {
                    "@list": [
                      {
                        "@id": "hasProcessingLocation"
                      },
                      {
                        "sh:zeroOrMorePath": {
                          "@id": "rdf:rest"
                        }
                      },
                      {
                        "@id": "rdf:first"
                      }
                    ]
                  },
                  "sh:minCount": 1,
                  "@type": "sh:PropertyShape"
                },
                {
                  "sh:path": {
                    "@list": [
                      {
                        "@id": "hasStorageLocation"
                      },
                      {
                        "sh:zeroOrMorePath": {
                          "@id": "rdf:rest"
                        }
                      },
                      {
                        "@id": "rdf:first"
                      }
                    ]
                  },
                  "sh:minCount": 1,
                  "@type": "sh:PropertyShape"
                },
                {
                  "sh:path": "hasExpiryTimeDuration",
                  "sh:minCount": 1,
                  "sh:maxCount": 1,
                  "sh:minInclusive": 0
                },
                {
                  "sh:path": "hasExpiryTimeUnit",
                  "sh:minCount": 1,
                  "sh:maxCount": 1,
                  "sh:in": {
                    "@list": [
                      "hour",
                      "day",
                      "week",
                      "month",
                      "year"
                    ]
                  }
                }
              ]
            },
            {
              "sh:path": "contractSchema",
              "sh:minCount": 1,
              "sh:maxCount": 1,
              "sh:property": [
                {
                  "sh:path": "repo",
                  "sh:minCount": 1,
                  "sh:maxCount": 1
                },
                {
                  "sh:path": "name",
                  "sh:minCount": 1,
                  "sh:maxCount": 1
                },
                {
                  "sh:path": "hash",
                  "sh:minCount": 1,
                  "sh:maxCount": 1
                }
              ]
            }
          ]
        },
        {
          "sh:path": {
            "@list": [
              {
                "@id": "dataModels"
              },
              {
                "sh:zeroOrMorePath": {
                  "@id": "rdf:rest"
                }
              },
              {
                "@id": "rdf:first"
              }
            ]
          },
          "sh:minCount": 0,
          "sh:property": [
            {
              "@type": "sh:PropertyShape",
              "sh:path": {
                "@list": [
                  {
                    "sh:zeroOrMorePath": {
                      "@id": "rdf:rest"
                    }
                  },
                  {
                    "@id": "rdf:first"
                  }
                ]
              },
              "sh:node": {
                "@type": "sh:NodeShape",
                "sh:property": [
                  {
                    "sh:path": "role",
                    "sh:minCount": 1,
                    "sh:maxCount": 1
                  },
                  {
                    "sh:path": "roleRequired",
                    "sh:minCount": 0,
                    "sh:maxCount": 1
                  },
                  {
                    "sh:path": "soyaSchema",
                    "sh:minCount": 0,
                    "sh:maxCount": 1,
                    "sh:property": [
                      {
                        "sh:path": "repo",
                        "sh:minCount": 1,
                        "sh:maxCount": 1
                      },
                      {
                        "sh:path": "name",
                        "sh:minCount": 1,
                        "sh:maxCount": 1
                      },
                      {
                        "sh:path": "hash",
                        "sh:minCount": 1,
                        "sh:maxCount": 1
                      }
                    ]
                  },
                  {
                    "sh:path": "descriptionDE",
                    "sh:minCount": 1,
                    "sh:maxCount": 1
                  },
                  {
                    "sh:path": "descriptionEN",
                    "sh:minCount": 0,
